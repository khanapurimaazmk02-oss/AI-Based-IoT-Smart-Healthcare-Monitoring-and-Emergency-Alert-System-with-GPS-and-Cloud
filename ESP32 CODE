#include <WiFi.h>
#include <HTTPClient.h>
#include <OneWire.h>
#include <DallasTemperature.h>
#include <Wire.h>
#include "MAX30105.h"
#include "heartRate.h"
#include <TinyGPS++.h>
#include <HardwareSerial.h>
#include "spo2_algorithm.h"

// ---------------- WIFI ----------------
const char* ssid = "Galaxy 5G Ali";
const char* password = "1234567890";

String firebaseURL = "https://iot-patient-health-monit-c67f6-default-rtdb.asia-southeast1.firebasedatabase.app/healthData.json";

// SENSORS pin configuration 
#define ONE_WIRE_BUS 4
#define LED_PIN 2  //LED
#define BUZZER_PIN 15//buzzer

MAX30105 particleSensor;
TinyGPSPlus gps;

HardwareSerial SerialAT(1);     // GSM
HardwareSerial gpsSerial(2);    // GPS

OneWire oneWire(ONE_WIRE_BUS);
DallasTemperature sensors(&oneWire);

//  VARIABLES of MAX30102
uint32_t irBuffer[100];
uint32_t redBuffer[100];

int32_t spo2;
int8_t validSPO2;
int32_t heartRate;
int8_t validHeartRate;

float temp = 0.0;
float latitude = 0.0;
float longitude = 0.0;

bool smsSent = false;


void setup() {

  Serial.begin(115200);

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(1000);
  }
  Serial.println("WiFi Connected");

  Wire.begin(21, 22);

  pinMode(LED_PIN, OUTPUT);
  pinMode(BUZZER_PIN, OUTPUT);

  gpsSerial.begin(9600, SERIAL_8N1, 16, 17);   // GPS RX=16 and TX=17
  SerialAT.begin(9600, SERIAL_8N1, 26, 27);    // GSM RX=26 and TX=27

  sensors.begin();

  if (!particleSensor.begin(Wire, I2C_SPEED_FAST)) {
    Serial.println("MAX30102 not found");
    while (1);
  }

  particleSensor.setPulseAmplitudeRed(0x0A);
  particleSensor.setPulseAmplitudeIR(0x0A);
}


void loop() {

  //code for pulse and spo2
  for (byte i = 0; i < 100; i++) {
    while (!particleSensor.available())
      particleSensor.check();

    redBuffer[i] = particleSensor.getRed();
    irBuffer[i] = particleSensor.getIR();
    particleSensor.nextSample();
  }

  maxim_heart_rate_and_oxygen_saturation(
    irBuffer, 100, redBuffer,
    &spo2, &validSPO2,
    &heartRate, &validHeartRate);

  if (validHeartRate && validSPO2) {
    Serial.println("Heart Rate = " + String(heartRate) + " BPM");
    Serial.println("SpO2 = " + String(spo2) + " %");
  }

  // code for body temprature
  sensors.requestTemperatures();
  temp = sensors.getTempCByIndex(0);

  Serial.println("Temperature = " + String(temp) + " °C");

  // code for gps
  while (gpsSerial.available()) {
    gps.encode(gpsSerial.read());
  }

  if (gps.location.isUpdated()) {
    latitude = gps.location.lat();
    longitude = gps.location.lng();

    Serial.println("Latitude = " + String(latitude, 6));
    Serial.println("Longitude = " + String(longitude, 6));
  }

  // code for sending data to fierbase
  if (WiFi.status() == WL_CONNECTED) {

    HTTPClient http;
    http.begin(firebaseURL);
    http.addHeader("Content-Type", "application/json");

    String json = "{";
    json += "\"heartRate\":" + String(heartRate) + ",";
    json += "\"spo2\":" + String(spo2) + ",";
    json += "\"temperature\":" + String(temp) + ",";
    json += "\"latitude\":" + String(latitude, 6) + ",";
    json += "\"longitude\":" + String(longitude, 6);
    json += "}";

    int response = http.PUT(json);
    Serial.println("Firebase Response: " + String(response));

    http.end();
  }

  checkEmergency();

  delay(5000);
}

// code emergency conditions
void checkEmergency() {

  if ((temp > 38.5 || temp < 35 ||
       heartRate > 120 || heartRate < 50 ||
       spo2 < 95) && !smsSent) {

    digitalWrite(LED_PIN, HIGH);
    digitalWrite(BUZZER_PIN, HIGH);

    Serial.println("EMERGENCY DETECTED");

    String locationLink = "https://www.google.com/maps?q=" +
                          String(latitude, 6) + "," +
                          String(longitude, 6);

    sendSMS(locationLink);
    smsSent = true;
  }

  if (temp <= 38.5 && temp >= 35 &&
      heartRate <= 120 && heartRate >= 50 &&
      spo2 >= 95) {

    digitalWrite(LED_PIN, LOW);
    digitalWrite(BUZZER_PIN, LOW);
    smsSent = false;
  }
}

// code for sending sms
void sendSMS(String locationLink) {

  SerialAT.println("AT+CMGF=1");
  delay(1000);

  SerialAT.println("AT+CMGS=\"+91XXXXXXXXXX\"");   // we have change the number 
  delay(1000);

  SerialAT.println("EMERGENCY! Patient Alert");
  SerialAT.println("Temperature: " + String(temp));
  SerialAT.println("Heart Rate: " + String(heartRate));
  SerialAT.println("SpO2: " + String(spo2));
  SerialAT.println("Location:");
  SerialAT.println(locationLink);

  SerialAT.write(26);
  delay(5000);

  Serial.println("Emergency SMS Sent");
}
